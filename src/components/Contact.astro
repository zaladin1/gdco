<section class="relative w-full py-20 lg:py-32 flex flex-col lg:flex-row items-center overflow-hidden">
  
  <!-- Left Content (Text Container) -->
  <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-start relative z-10">
    <div class="w-full lg:max-w-[50%] lg:pr-16">
      
      <!-- Updated color and size to match your theme -->
      <h2 class="text-3xl lg:text-4xl font-serif font-bold text-[#0c2340]">
        Contact Us
      </h2>
      
      <p class="mt-6 text-slate-700 leading-relaxed text-lg sm:text-[1.1rem]">
        If you would like to receive further information about Ginakes, Damianakos and Company, or indeed any of the services we provide, please get in touch, and we will be in contact with you directly. Opening hours 9am to 5pm weekdays. Out of hours appointments and home visits by prior arrangement.
      </p>
      
      <a href="#" class="inline-flex items-center mt-8 text-[#a57b68] hover:text-[#8a6352] transition-colors border-b border-[#a57b68] pb-1 text-lg font-medium">
        find out more <span class="ml-2">&rarr;</span>
      </a>
      
    </div>
  </div>

  <!-- Right Content (Image Bleed) -->
  <!-- lg:w-[48vw] and lg:right-0 forces it to stick to the absolute right edge of the screen -->
  <div class="relative w-full h-[350px] sm:h-[450px] lg:h-auto mt-12 lg:mt-0 lg:absolute lg:right-0 lg:top-[5%] lg:bottom-[5%] lg:w-[48vw] xl:w-[45vw] flex justify-end items-center z-0">
    
    <!-- object-contain object-right ensures it scales without cropping and glues to the right side -->
    <img 
      src="/contact-shop.png" 
      alt="Storefront Illustration" 
      class="w-full h-full max-h-[90%] object-contain object-right drop-shadow-sm pointer-events-none" 
    />
    
  </div>

</section>